# ─────────────────────────────────────────────────────────────────────────────
# TRADING BOT — ENVIRONMENT VARIABLES
# ─────────────────────────────────────────────────────────────────────────────
# HOW TO USE:
#   1. Copy this file and rename it to ".env"  (remove ".example")
#   2. Fill in your values
#   3. Never share .env or commit it to git
# ─────────────────────────────────────────────────────────────────────────────

# ─── TRADING MODE ─────────────────────────────────────────────────────────────
# MANUAL_TRADING=True  → bot sends alerts to phone, YOU place orders on Kite app
# MANUAL_TRADING=False → bot places orders automatically via Kite API (needs API key)
MANUAL_TRADING=True

# PAPER_TRADING only matters when MANUAL_TRADING=False
# True  = simulate orders (no real money)
# False = real live orders via Kite API
PAPER_TRADING=True

# ─── CAPITAL ──────────────────────────────────────────────────────────────────
INITIAL_CAPITAL=20000

# ─── KITE CONNECT API ─────────────────────────────────────────────────────────
# Get these from https://kite.trade → Create app → Personal
# Leave blank for paper trading
KITE_API_KEY=
KITE_API_SECRET=

# ─── ZERODHA AUTO-LOGIN (for auto_auth.py) ────────────────────────────────────
# These allow the bot to log in to Kite automatically every morning.
# ZERODHA_USER_ID    : Your Zerodha client ID (e.g. AB1234)
# ZERODHA_PASSWORD   : Your Zerodha login password
# ZERODHA_TOTP_SECRET: The BASE32 secret from your Zerodha TOTP setup.
#                      To get this: Zerodha → My Profile → Security → 2FA
#                      → Enable TOTP → when QR code appears, click
#                      "Can't scan? Use secret key instead" → copy that key.
#                      NOTE: This is NOT the 6-digit OTP — it's the long key.
ZERODHA_USER_ID=
ZERODHA_PASSWORD=
ZERODHA_TOTP_SECRET=

# ─── EMAIL ALERTS (Gmail) ─────────────────────────────────────────────────────
# Bot sends trade alerts to your phone via email.
# Recommended: create a dedicated Gmail e.g. niftybot2026@gmail.com to send from.
#
# How to get the App Password (one-time, 2 minutes):
#   1. Go to myaccount.google.com → Security → enable 2-Step Verification
#   2. Go to myaccount.google.com/apppasswords
#   3. Name it "NiftyBot" → Generate → copy the 16-character password shown
#
# ALERT_EMAIL_FROM         : Gmail that SENDS the alert
# ALERT_EMAIL_APP_PASSWORD : 16-char app password (NOT your Gmail login password)
# ALERT_EMAIL_TO           : Email on your phone that RECEIVES the alert
ALERT_EMAIL_FROM=
ALERT_EMAIL_APP_PASSWORD=
ALERT_EMAIL_TO=

# ─── TELEGRAM ALERTS (optional, legacy) ───────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
